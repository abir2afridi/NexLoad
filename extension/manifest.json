{
  "manifest_version": 3,
  "name": "NexLoad Cookie Exporter",
  "version": "2.0.0",
  "description": "Export YouTube cookies for NexLoad — shows which websites cookies come from, YouTube priority",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.google.com/*",
    "https://*.googlevideo.com/*",
    "https://*.ytimg.com/*",
    "https://nex-load.vercel.app/*",
    "https://*.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NexLoad Cookie Exporter"
  },
  "background": {
    "service_worker": "background.js"
  }
}
