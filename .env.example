# Server
PORT=3000
NODE_ENV=development

# Optional: YouTube Data API key for search (falls back to mock results)
YOUTUBE_API_KEY=

# Rate limits (per minute per IP)
RATE_LIMIT_ANALYZE=30
RATE_LIMIT_DOWNLOAD=10
RATE_LIMIT_SEARCH=60

# Processing
TEMP_DIR=/tmp/nexload
MAX_FILE_SIZE_GB=2
CLEANUP_INTERVAL_MINUTES=10

# Queue
MAX_CONCURRENT_DOWNLOADS=3

# Cache (in-memory)
METADATA_CACHE_MAX=200
METADATA_CACHE_TTL_MINUTES=5
